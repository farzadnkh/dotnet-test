<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- To inherit global NuGet sources, remove the <clear/> line below -->
    <clear />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
    <!-- Private feed: add your GitLab NuGet URL and credentials in user-level NuGet.Config
         or run: dotnet nuget add source "<feed-url>" -n ntt-nuget -u <username> -p <token> --store-password-in-clear-text -->
    <add key="ntt-nuget" value="https://gitlab.com/api/v4/projects/YOUR_PROJECT_ID/packages/nuget/index.json" />
  </packageSources>
</configuration>
