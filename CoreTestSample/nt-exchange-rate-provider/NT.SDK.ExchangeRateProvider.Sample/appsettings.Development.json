{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ExchangeRateProivder": {
    "CachePrefix": "ExRP",
    "TokenExpireInSec": 3600
  },
  "VaultOption": {
    "RedisSecrets": {
      "CredentialsMountPoint": "exrp_credentials",
      "ConnectionKey": "RedisCredentials"
    },
    "ExchangeRateSecrets": {
      "CredentialsMountPoint": "exrp_credentials",
      "ConnectionKey": "exrp_secrets"
    }
  }
}
