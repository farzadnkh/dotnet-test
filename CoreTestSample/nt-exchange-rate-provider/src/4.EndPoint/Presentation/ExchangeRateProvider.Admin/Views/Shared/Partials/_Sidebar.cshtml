<!-- Sidebar Treeview Toggle Script -->
<script>
	document.addEventListener('DOMContentLoaded', function() {
		const navItemsWithSubmenu = document.querySelectorAll('.nav-item.has-treeview > a');
		const nav = document.querySelector('.nav');
		const accordionEnabled = nav ? nav.dataset.accordion !== 'false' : true;

		$('.nav-item').each(function () {
			let currentUri = window.location.pathname.toLowerCase();
			let hrefs = $(this).find('.nav-link').attr('href')?.toLowerCase();
			if(currentUri != "/home/index" && hrefs != undefined){
				if(hrefs.split('/')[1] == currentUri.split('/')[1])
					 $(this).find('.nav-link').addClass("active");
				else
					$(this).find('.nav-link').removeClass("active");
				}
		});

		(function restoreActiveTreeview() {
			const activeLink = document.querySelector('.nav-link.active');
			if (activeLink) {
				const treeviewItem = activeLink.closest('.nav-item.has-treeview');
				if (treeviewItem) {
					const subMenu = treeviewItem.querySelector('.nav-treeview');
					const icon = treeviewItem.querySelector('.right.fas');

					if (subMenu) {
						subMenu.style.display = 'block'; // Keep submenu open
					}
					if (icon) {
						icon.classList.remove('fa-angle-down');
						icon.classList.add('fa-angle-up');
					}
				}
			}
		})();

		navItemsWithSubmenu.forEach(function(anchor) {
			anchor.addEventListener('click', function(event) {
				event.preventDefault();

				const parent = this.closest('.nav-item');
				const subMenu = parent.querySelector('.nav-treeview');
				const icon = this.querySelector('.right.fas');

				if (!subMenu) {
					return;
				}

				if (accordionEnabled) {
					const allParentItems = document.querySelectorAll('.nav-item.has-treeview');
					allParentItems.forEach(function(otherParent) {
						if (otherParent !== parent) {
							const otherSubMenu = otherParent.querySelector('.nav-treeview');
							const otherIcon = otherParent.querySelector('.right.fas');
							if (otherSubMenu && otherSubMenu.style.display === 'block') {
								slideUp(otherSubMenu, 'fast');
								if (otherIcon) {
									otherIcon.classList.remove('fa-angle-up');
									otherIcon.classList.add('fa-angle-down');
								}
							}
						}
					});
				}

				if (subMenu.style.display === 'block') {
					slideUp(subMenu, 'fast');
				} else {
					slideDown(subMenu, 'fast');
				}

				if (icon) {
					icon.classList.toggle('fa-angle-down');
					icon.classList.toggle('fa-angle-up');
				}
			});
		});

		function slideUp(element, speed) {
			element.style.overflow = 'hidden';
			element.style.transition = `height ${speed === 'fast' ? '0.2s' : '0.4s'} ease-in-out`;
			element.style.height = 0;
			setTimeout(() => {
				element.style.display = 'none';
				element.style.removeProperty('height');
				element.style.removeProperty('overflow');
				element.style.removeProperty('transition');
			}, speed === 'fast' ? 200 : 400);
		}

		function slideDown(element, speed) {
			element.style.display = 'block';
			const height = element.offsetHeight;
			element.style.overflow = 'hidden';
			element.style.height = 0;
			element.style.transition = `height ${speed === 'fast' ? '0.2s' : '0.4s'} ease-in-out`;
			requestAnimationFrame(() => {
				element.style.height = height + 'px';
			});
			setTimeout(() => {
				element.style.removeProperty('height');
				element.style.removeProperty('overflow');
				element.style.removeProperty('transition');
			}, speed === 'fast' ? 200 : 400);
		}
	});
</script>
