<style>
    .logout-button {
        padding: 0.3rem 0.75rem;
        font-size: 0.8rem;
        line-height: 1.2;
        border-radius: 4px;
        box-shadow: none;
    }

        .logout-button:hover {
            background-color: #b8860b;
            color: white;
        }
</style>



<script>
    function display_c() {
        setTimeout(display_ct, 1000);
    }

    function display_ct() {
        const now = new Date();

        const options = {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour12: false
        };

        const dateTime = new Intl.DateTimeFormat(undefined, options).format(now);

        document.getElementById('datetime-now-top').innerText = dateTime;

        display_c();
    }

    display_c();
</script>