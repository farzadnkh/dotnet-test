@model ResponseWrapper<CreateConsumerModel>

@{
    ViewData["Title"] = "Consumers";
    Layout = "_Layout";
    bool isFirstLoad = false;
}

<div class="container-fluid mt-4">
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="information-tab" data-bs-toggle="tab" data-bs-target="#information"
                    type="button" role="tab">Information
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="security-tab" data-bs-toggle="tab" data-bs-target="#security" type="button"
                    role="tab">Security
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="business-tab" data-bs-toggle="tab" data-bs-target="#business" type="button"
                    role="tab">Business
            </button>
        </li>
    </ul>

    <div class="tab-content mt-3">
        <div class="tab-pane fade show active" id="information" role="tabpanel">
            @await Html.PartialAsync("Information", Model)
        </div>
        <div class="tab-pane fade" id="security" role="tabpanel">
            @await Html.PartialAsync("Security")
        </div>
        <div class="tab-pane fade" id="business" role="tabpanel">
            @await Html.PartialAsync("Business")
        </div>
    </div>
</div>

<script>
    const isFirstLoad = @isFirstLoad.ToString().ToLower();
    
    if (!isFirstLoad) {
        const securityTab = document.querySelector('#security-tab');
        securityTab.classList.remove('disabled'); // Enable it
        const tab = new bootstrap.Tab(securityTab);
        tab.show(); // Switch

        const tabPaneInfo = document.querySelector('#information');
        tabPaneInfo.classList.remove('show', 'active');

        const tabPaneSecurity = document.querySelector('#security');
        tabPaneSecurity.classList.add('show', 'active');

        const businessTab = document.querySelector('#business-tab');
        businessTab.classList.remove('disabled'); // Enable it

        isFirstLoad = true;
    }   
</script>