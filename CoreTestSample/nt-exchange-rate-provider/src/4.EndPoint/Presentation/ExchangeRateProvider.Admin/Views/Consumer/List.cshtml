@using ExchangeRateProvider.Admin.Models.Consumers

@model ListViewModel
@{
	ViewData["Title"] = "Consumers";
	Layout = "_Layout";
}

<h1>Consumers List</h1>

<form asp-controller="Consumer" asp-action="list" method="get" class="mb-4">
	<div class="row" style="align-items: center;">
		<div class="col-md-2">
			<strong for="UserName">UserName:</strong>
			@Html.TextBox("UserName", Model.UserName, new { @class = "form-control", @placeholder = "" })
		</div>
		<div class="col-md-2">
			<strong for="ProjectName">ProjectName:</strong>
			@Html.TextBox("ProjectName", Model.ProjectName, new { @class = "form-control", @placeholder = "" })
		</div>
		<div class="col-md-2">
			<strong for="IsActive">IsActive:</strong>
			@Html.DropDownList("IsActive", Model.ActiveOptions, new { @class = "form-control", @placeholder = "Select Type" })
		</div>
		<div class="col-md-2 mt-4">
			<button type="submit" class="btn btn-success btn-sm">Search</button>
			<a asp-controller="Consumer" asp-action="AddConsumer" class="btn btn-info btn-sm">Create</a>
		</div>
	</div>
</form>

<div class="d-flex justify-content-end mb-3">
	<form asp-controller="Consumer" asp-action="List" method="get" id="pageSizeForm">
		<div class="input-group">
			<label for="Size" class="input-group-text">Items per page:</label>
			@Html.DropDownList("Size", Model.SizeOptions, new { @class = "form-select", onchange = "this.form.submit();" })
			<input type="hidden" name="index" value="@Model.PaginationResponse.Base.Index"/>
		</div>
	</form>
</div>

<div class="table-responsive">
	<table class="table table-striped">
		<thead>
		<tr>
			<th>ProjectName</th>
			<th>UserName</th>
			<th>IsActive</th>
			<th>CreatedAt</th>
			<th>Action</th>
		</tr>
		</thead>
		<tbody>
		@foreach (var consumer in Model.PaginationResponse.Items)
		{
			<tr>
				<td>@consumer.ProjectName</td>
				<td>@consumer.UserName</td>
				<td>@(consumer.IsActive ? "✅" : "❌")</td>
				<td>@consumer.CreatedAt</td>
				<td class="action d-flex align-items-center">
					<a asp-controller="Consumer" asp-action="Edit" asp-route-id="@consumer.Id" class="nav-link active">
						<i class="fa fa-edit"></i>
					</a>
					<button type="button" class="btn btn-sm btn-primary list-btn open-deactive-modal"
					        data-id="@consumer.Id">
						<i class="fa fa-times"></i>
					</button>
				</td>
			</tr>
		}
		</tbody>
	</table>
</div>

<nav aria-label="Consumer Pagination" class="mt-4">
	<ul class="pagination justify-content-center">
		@{
			var totalPages = Model.PaginationResponse.Base.Total;
			var currentPage = Model.PaginationResponse.Base.Index;
		}

		<li class="page-item @(currentPage <= 1 ? "disabled" : "")">
			<a class="page-link" asp-route-index="@(currentPage - 1)" asp-route-size="@Model.PaginationResponse.Base.Size">Previous</a>
		</li>

		@for (int i = 1; i <= totalPages; i++)
		{
			<li class="page-item @(i == currentPage ? "active" : "")">
				<a class="page-link" asp-route-index="@i" asp-route-size="@Model.PaginationResponse.Base.Size">@i</a>
			</li>
		}

		<li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
			<a class="page-link" asp-route-index="@(currentPage + 1)" asp-route-size="@Model.PaginationResponse.Base.Size">Next</a>
		</li>
	</ul>
</nav>



<div id="tokenModal" class="modal fade" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered animate__animated">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Client Token</h5>
			</div>
			<div class="modal-body">
				<input type="text" id="tokenInput" class="form-control mb-3" readonly/>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary ok-btn" data-bs-dismiss="modal">OK</button>
				<button type="button" id="copyTokenBtn" class="btn btn-primary">Copy</button>
			</div>
		</div>
	</div>
</div>

<div id="deactiveModal" class="modal fade" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered animate__animated">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Confirm Deactivation</h5>
			</div>
			<div class="modal-body">
				<p>Are you sure you want to deactivate this consumer?</p>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-success deactive-btn">Yes</button>
				<button type="button" class="btn btn-danger cancel-btn" data-bs-dismiss="modal">Cancel</button>
			</div>
		</div>
	</div>
</div>

<divc class="loader-overlay" id="loaderOverlay">
	<div class="spinner-border text-primary" role="status">
		<span class="visually-hidden">Loading...</span>
	</div>
</divc>

<script src="~/js/consumer.js"></script>    