{
  "LoggerOptions": {
    "WithExceptionDetails": true,
    "MinimumLevel": "Error",
    "Overrides": [
      {
        "Source": "Elastic.Apm",
        "MinimumLevel": "Error"
      },
      {
        "Source": "Microsoft",
        "MinimumLevel": "Error"
      }
    ],
    "ElasticOptions": {
      "ActiveMode": true,
      "DataStream": {
        "Type": "ex",
        "DataSet": "Core.Admin",
        "NameSpace": "ExchangeProvider"
      }
    },
    "FileOptions": {
      "MinimumLevel": "Error",
      "ActiveMode": false,
      "Path": "logs/logs.txt"
    },
    "ConsoleOptions": {
      "MinimumLevel": "Verbose",
      "ActiveMode": false
    },
    "DebugOptions": {
      "MinimumLevel": "Debug",
      "ActiveMode": false
    }
  },
  "VaultOption": {
    "MsSqlSecrets": {
      "CredentialsMountPoint": "exrp_test_credentials",
      "ConnectionKey": "ex_mssql_connection"
    },
    "RedisSecrets": {
      "CredentialsMountPoint": "exrp_test_credentials",
      "ConnectionKey": "RedisCredentials"
    },
    "LogsSecrets": {
      "CredentialsMountPoint": "exrp_test_credentials",
      "ConnectionKey": "logs_credentials"
    },
    "ElasticSecrets": {
      "CredentialsMountPoint": "exrp_test_credentials",
      "ConnectionKey": "elasticapm_credentials"
    },
    "MasstransitSecrets": {
      "CredentialsMountPoint": "exrp_test_credentials",
      "ConnectionKey": "masstransit"
    },
    "GlobalCredentialsMountPoint": "exrp_test_credentials"
  },
  "SeedIdp": false,
  "RedisOption": {
    "HangFireDatabase": 4,
    "DefaultDatabase": 2
  }
}